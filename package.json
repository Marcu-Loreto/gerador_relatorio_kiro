{
  "private": true,
  "scripts": {
    "start": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,green\" --handle-input \"npm run backend\" \"npm run frontend\"",
    "backend": "PYTHONPATH=apps/backend .venv/bin/python -m uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload",
    "frontend": "npm run dev --prefix apps/frontend",
    "stop": "pkill -f 'uvicorn src.api.main' ; pkill -f 'vite' ; echo 'Serviços encerrados'"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
