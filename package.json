{
  "private": true,
  "scripts": {
    "start": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run backend\" \"npm run frontend\"",
    "backend": "PYTHONPATH=apps/backend .venv/bin/python -m uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload",
    "frontend": "npm run dev --prefix apps/frontend",
    "dev:backend": "npm run backend",
    "dev:frontend": "npm run frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
