# Application
APP_NAME=gerador_relatorio_kiro
APP_VERSION=1.0.0
ENVIRONMENT=development

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_WORKERS=4

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Gerador de Relatórios

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/relatorio_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key
MINIMAX_API_KEY=your-minimax-api-key

# Model Selection Strategy
MODEL_SELECTION_STRATEGY=auto  # auto, simple, complex, or specific model name
SIMPLE_MODEL=minimax-m2.5  # Free model for simple tasks
COMPLEX_MODEL=gpt-4o  # Premium model for complex tasks

# Model Parameters
DEFAULT_TEMPERATURE=0.3
DEFAULT_MAX_TOKENS=4096
SIMPLE_TASK_MAX_TOKENS=2048
COMPLEX_TASK_MAX_TOKENS=8192

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.xlsx,.csv,.txt,.pptx,.md

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Observability
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
ENABLE_SECURITY_GUARD=true
ENABLE_PROMPT_INJECTION_DETECTION=true
MAX_REVISION_ATTEMPTS=3
