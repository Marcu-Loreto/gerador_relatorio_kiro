# Application
APP_NAME=gerador_relatorio_kiro
APP_VERSION=1.0.0
ENVIRONMENT=development

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_WORKERS=4

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Gerador de Relatórios

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
ALLOWED_ORIGINS_STR=http://localhost:5173,http://localhost:3000

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key
MINIMAX_API_KEY=your-minimax-api-key

# Model Selection Strategy
MODEL_SELECTION_STRATEGY=auto
SIMPLE_MODEL=gpt-4o-mini
COMPLEX_MODEL=gpt-4o

# Model Parameters
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096
SIMPLE_TASK_MAX_TOKENS=2048
COMPLEX_TASK_MAX_TOKENS=8192

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS_STR=.pdf,.docx,.xlsx,.xls,.csv,.txt,.pptx,.md

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security Features
ENABLE_SECURITY_GUARD=true
ENABLE_PROMPT_INJECTION_DETECTION=true
MAX_REVISION_ATTEMPTS=3
